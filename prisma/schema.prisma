model SupportQA {
  id         String             @id @default(uuid())
  user_id    String
  user       User               @relation(fields: [user_id], references: [id])
  title      String
  content    String
  is_answer  Boolean            @default(false)
  created_at DateTime           @default(now())
  updated_at DateTime           @updatedAt
  comments   SupportQAComment[]
}

model SupportQAComment {
  id         String    @id @default(uuid())
  qa_id      String
  qa         SupportQA @relation(fields: [qa_id], references: [id], onDelete: Cascade)
  user_id    String
  user       User      @relation(fields: [user_id], references: [id])
  content    String
  is_admin   Boolean   @default(false)
  created_at DateTime  @default(now())
}

model VerificationToken {
  id         String   @id @default(uuid())
  token      String   @unique
  data       Json     // { ci, name, birthDate, gender, phone }
  expires_at DateTime
  created_at DateTime @default(now())
}

model LegacyMember {
  id          String   @id @default(uuid())
  username    String   @unique // 기존 사이트 아이디
  name        String?          // 기존 사이트 이름
  birthdate   String?          // 생년월일 (예: 2002-11-08)
  phone       String?          // 연락처
  role        String?          // 업소회원 / 개인회원
  is_migrated Boolean  @default(false) // 이사 완료 여부
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([username])
}
model JobUpdateLog {
  id              String   @id @default(uuid())
  job_id          String
  job             Job      @relation(fields: [job_id], references: [id], onDelete: Cascade)
  user_id         String?  // 수정자 ID (관리자 혹은 업주)
  user            User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  
  before_data     Json     // 변경 전 데이터 (필요한 필드만 JSON 스냅샷)
  after_data      Json     // 변경 후 데이터 (필요한 필드만 JSON 스냅샷)
  changed_fields  String[] // 변경된 필드 목록 (뱃지용: ["title", "description"])
  
  ip_address      String?
  created_at      DateTime @default(now())

  @@index([job_id, created_at(sort: Desc)])
  @@index([created_at(sort: Desc)])
}

model SmsLog {
  id            String   @id @default(uuid())
  to            String
  message       String
  type          String   // EXPIRY_2D, EXPIRY_1D, EXPIRED_1D, PAYMENT_INFO, etc.
  status        SmsStatus @default(PENDING)
  error_message String?
  created_at    DateTime @default(now())

  @@index([to])
  @@index([created_at(sort: Desc)])
}

enum SmsStatus {
  PENDING
  SUCCESS
  FAILURE
}
model Resume {
  id          String   @id @default(uuid())
  user_id     String   @unique
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  nickname    String?
  age         Int?
  region      String?
  occupation  String?
  content     String   @db.Text
  
  images      ResumeImage[]
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model ResumeImage {
  id         String   @id @default(uuid())
  resume_id  String
  resume     Resume   @relation(fields: [resume_id], references: [id], onDelete: Cascade)
  image_url  String
  created_at DateTime @default(now())
}

model ResumeNotice {
  id         Int      @id @default(1)
  content    String   @db.Text
  updated_at DateTime @updatedAt
}
