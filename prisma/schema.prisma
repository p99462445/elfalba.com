generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  old_id          String?        // 기존 사이트 문자형 아이디 보존용
  contact_email   String?        // 기존 사이트 실제 이메일 보존용
  password        String?
  name            String?
  nickname        String?
  phone           String?
  role            Role           @default(USER)
  status          UserStatus     @default(ACTIVE)
  provider        String?
  provider_id     String?
  telegram        String?
  kakao           String?
  referral_source String?
  birthdate       String?
  real_name       String?      // 인증된 실명
  ci              String?      // 중복가입 체크용 (업주는 중복 허용)
  is_adult        Boolean      @default(false) // 성인 여부 (만 19세)
  verified_at     DateTime?    // 본인인증 완료 시간
  terms_agreed    Boolean        @default(false)
  privacy_agreed  Boolean        @default(false)
  gender          String?        @default("UNKNOWN")
  sms_consent     Boolean        @default(false)

  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  deleted_at      DateTime?
  last_login      DateTime?
  signup_ip       String?

  employer        Employer?
  applications    JobApplication[]
  payments        Payment[]
  bookmarks       Bookmark[]
  notifications   Notification[]
  posts           Post[]
  comments        Comment[]
  supportQAs      SupportQA[]
  supportQAComments SupportQAComment[]
  
  // Chat relations
  chat_rooms_as_user1 ChatRoom[] @relation("User1Rooms")
  chat_rooms_as_user2 ChatRoom[] @relation("User2Rooms")
  messages            Message[]
  login_logs          LoginLog[]
  job_update_logs     JobUpdateLog[]
  resume              Resume?
}

model LoginLog {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ip         String?
  user_agent String?
  created_at DateTime @default(now())

  @@index([user_id, created_at(sort: Desc)])
}

// ... existing enums ...

model ChatRoom {
  id          String   @id @default(uuid())
  user1_id    String
  user2_id    String
  user1       User     @relation("User1Rooms", fields: [user1_id], references: [id])
  user2       User     @relation("User2Rooms", fields: [user2_id], references: [id])
  
  last_message String?
  last_message_at DateTime @default(now())
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  messages    Message[]

  @@unique([user1_id, user2_id])
}

model Message {
  id          String   @id @default(uuid())
  room_id     String
  room        ChatRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)
  sender_id   String
  sender      User     @relation(fields: [sender_id], references: [id])
  
  content     String
  is_read     Boolean  @default(false)
  
  created_at  DateTime @default(now())
}


enum Role {
  USER
  EMPLOYER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  PENDING
  DELETED
}

model Employer {
  id                   String             @id @default(uuid())
  user                 User               @relation(fields: [user_id], references: [id])
  user_id              String             @unique
  business_name        String
  business_number      String?
  owner_name           String?
  phone                String?
  address              String?
  address_detail       String?
  business_license_url String?
  verification_status  VerificationStatus @default(PENDING)
  community_pass_expired_at DateTime?
  jump_points          Int                @default(10)

  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt

  jobs                 Job[]
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Region {
  id          Int         @id @default(autoincrement())
  parent_id   Int?
  parent      Region?     @relation("RegionToRegion", fields: [parent_id], references: [id])
  children    Region[]    @relation("RegionToRegion")
  name        String
  slug        String      @unique
  created_at  DateTime    @default(now())
  jobs        Job[]
  job_regions JobRegion[]
}

model JobCategory {
  id         Int           @id @default(autoincrement())
  parent_id  Int?
  parent     JobCategory?  @relation("CategoryToCategory", fields: [parent_id], references: [id])
  children   JobCategory[] @relation("CategoryToCategory")
  name       String
  slug       String        @unique
  created_at DateTime      @default(now())
  jobs       Job[]
}

model Job {
  id                     String         @id @default(uuid())
  job_no                 Int            @unique @default(autoincrement())
  legacy_id              Int?           @unique // 기존 사이트 공고 번호 보존용
  employer_id            String
  employer               Employer       @relation(fields: [employer_id], references: [id])
  category_id            Int
  category               JobCategory    @relation(fields: [category_id], references: [id])
  region_id              Int?           // Optional primary region
  region                 Region?        @relation(fields: [region_id], references: [id])
  regions                JobRegion[]

  title                  String
  business_name          String?        // 상호명 (공고별 별도 설정)
  description            String
  qualifications         String?
  manager_name           String?        // 담당자 실명
  kakao_id               String?
  telegram_id            String?
  line_id                String?
  salary_type            SalaryType     @default(HOURLY)
  salary_amount          Int            @default(0)
  salary_info            String?
  working_type           String?        @default("파트타임 / 단기") // 근무형태
  employment_type        String?        @default("고용")          // 고용형태
  work_time              String?
  working_hours          String?
  contact_type           ContactType    @default(PHONE)
  contact_value          String         @default("")
  contact_info           String?
  convenience_tags       String[]
  age_min                Int?
  age_max                Int?
  gender                 String?        @default("무관")
  status                 JobStatus      @default(PENDING)
  exposure_level         ExposureLevel  @default(GENERAL)

  logo_url               String?
  view_count             Int            @default(0)
  last_jumped_at         DateTime       @default(now())
  
  // 관리자 전용 악녀알바 공식파트너 기능
  is_official_partner         Boolean   @default(false)
  official_partner_expires_at DateTime?

  remaining_auto_jumps   Int            @default(0)
  auto_jump_interval_min Int            @default(144)
  is_auto_jump_enabled   Boolean        @default(true)
  next_auto_jump_at      DateTime?

  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  
  // 기존 공통 마감일 (Legacy - 데이터 보존용/점프 계산용으로 유지)
  expired_at             DateTime?

  // 신규: 독립적인 등급별 마감일 (폭포수 시스템용)
  vvip_expired_at        DateTime?
  vip_expired_at         DateTime?
  normal_expired_at      DateTime?

  // 공고별 커스텀 사업자 정보
  official_business_name String?
  business_address    String?
  business_owner_name String?
  banner_url          String?

  images                 JobImage[]
  applications           JobApplication[]
  bookmarks              Bookmark[]
  payments               Payment[]
  auto_jumps             AutoJump[]
  update_logs            JobUpdateLog[]

  @@index([status, exposure_level, last_jumped_at(sort: Desc)])
}

model JobRegion {
  job_id    String
  region_id Int
  job       Job    @relation(fields: [job_id], references: [id], onDelete: Cascade)
  region    Region @relation(fields: [region_id], references: [id], onDelete: Cascade)

  @@id([job_id, region_id])
}

enum SalaryType {
  TC
  HOURLY
  MONTHLY
  NEGOTIABLE
}

enum ContactType {
  PHONE
  KAKAO
  TELEGRAM
  EMAIL
}

enum JobStatus {
  PENDING
  ACTIVE
  PAUSED
  EXPIRED
  REJECTED
}

enum ExposureLevel {
  VVIP
  VIP
  GENERAL
}

model JobImage {
  id         String   @id @default(uuid())
  job_id     String
  job        Job      @relation(fields: [job_id], references: [id], onDelete: Cascade)
  image_url  String
  created_at DateTime @default(now())
}

model JobApplication {
  id          String            @id @default(uuid())
  job_id      String
  job         Job               @relation(fields: [job_id], references: [id])
  user_id     String
  user        User              @relation(fields: [user_id], references: [id])
  status      ApplicationStatus @default(NEW)
  resume_text String?
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
}

enum ApplicationStatus {
  NEW
  VIEWED
  CONTACTED
  REJECTED
}

model Product {
  id            String      @id @default(uuid())
  name          String
  price         Int
  duration_days Int?
  jump_count    Int?
  product_type  ProductType
  created_at    DateTime    @default(now())
  payments      Payment[]
}

enum ProductType {
  VVIP_SLOT
  VIP_SLOT
  GENERAL_SLOT
  JUMP_COIN
}

model Payment {
  id                String        @id @default(uuid())
  user_id           String
  user              User          @relation(fields: [user_id], references: [id])
  product_id        String
  product           Product       @relation(fields: [product_id], references: [id])
  job_id            String?
  job               Job?          @relation(fields: [job_id], references: [id])
  
  amount            Int
  depositor_name    String?
  payment_method    PaymentMethod @default(BANK_TRANSFER)
  status            PaymentStatus @default(PENDING)
  pg_transaction_id String?
  receipt_url       String?
  payment_info      Json?

  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  VIRTUAL_ACCOUNT
}

enum PaymentStatus {
  PENDING
  APPROVED
  CANCELED
  REFUNDED
  FAILED
}

model Bookmark {
  user_id    String
  job_id     String
  user       User     @relation(fields: [user_id], references: [id])
  job        Job      @relation(fields: [job_id], references: [id])
  created_at DateTime @default(now())

  @@id([user_id, job_id])
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  type       String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
}

model AutoJump {
  id               String   @id @default(uuid())
  job_id           String
  job              Job      @relation(fields: [job_id], references: [id])
  interval_minutes Int
  remaining_count  Int
  next_jump_at     DateTime
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
}

model Post {
  id         String    @id @default(uuid())
  user_id    String
  user       User      @relation(fields: [user_id], references: [id])
  title      String
  content    String
  category   String    @default("자유")
  view_count Int       @default(0)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  comments   Comment[]
  likes      PostLike[]
}

model PostLike {
  post_id    String
  user_id    String
  post       Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@id([post_id, user_id])
}

model Comment {
  id         String    @id @default(uuid())
  post_id    String
  post       Post      @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user_id    String
  user       User      @relation(fields: [user_id], references: [id])
  content    String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
}

model Notice {
  id           String   @id @default(uuid())
  title        String
  content      String
  is_important Boolean  @default(false)
  view_count   Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model FAQ {
  id         String   @id @default(uuid())
  question   String
  answer     String
  category   String
  order      Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

